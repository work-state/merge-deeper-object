{
  "version": "1.0.0",
  "author": "Ilyass Mabrouk",
  "license": "MIT",
  "name": "merge-deeper-object",
  "description": "Deep merge utility for nested objects.",
  "homepage": "https://github.com/work-state/merge-deeper-object",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/work-state/merge-deeper-object.git"
  },
  "bugs": {
    "url": "https://github.com/work-state/merge-deeper-object/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "files": ["dist"],
  "scripts": {
    "test": "vitest run",
    "build": "rollup -c",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "object",
    "objects",
    "nested",
    "deep",
    "deeper",
    "merge",
    "combine",
    "clone deep",
    "keys",
    "key",
    "values",
    "value",
    "properties",
    "property",
    "entries",
    "entry",
    "recursive"
  ],
  "verb": {
    "tasks": [
      "readme"
    ],
    "reflinks": [
      "verb"
    ],
    "lint": {
      "reflinks": true
    }
  },
  "devDependencies": {
    "rollup": "^4.59.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=14"
  }
}
