{
  "singleQuote": true,
  "trailingComma": "es5",
  "printWidth": 80,
  "tabWidth": 2,
  "semi": true,
  "overrides": [
    {
      "files":["*.json", ".prettierrc"],
      "options": {
          "parser": "json"
        }
    },
    {
      "files": "*.js",
      "options": {
          "parser": "flow"
        }
    }
  ]
}
